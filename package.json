{
  "name": "identity-hub-backend",
  "version": "0.1.0",
  "description": "IdentityHub Jira integration backend (POC)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "gen:key": "node scripts/gen-key.mjs",
    "digest": "tsx scripts/blog-digest.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^4.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
