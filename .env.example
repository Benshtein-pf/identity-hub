# Copy this file to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

# Public origin of this API. Used as the default basis for the Jira OAuth
# redirect_uri and is otherwise informational.
APP_BASE_URL=http://localhost:3000

# Origin of the (separately built) frontend. The browser is redirected here
# after the Jira OAuth callback completes: ${FRONTEND_URL}/jira/connected?status=success|error
FRONTEND_URL=http://localhost:5173

# SQLite file path. Created automatically on first boot if it does not exist.
DATABASE_PATH=./data/identity-hub.sqlite

# AES-256-GCM key for encrypting Jira OAuth tokens at rest. Must be base64 for
# exactly 32 bytes. Generate one with: npm run gen:key
APP_ENCRYPTION_KEY=

# Atlassian OAuth 2.0 (3LO) app credentials. Create one at
# https://developer.atlassian.com/console/myapps/ -> "Create app" -> OAuth 2.0
# integration. Add the scopes read:jira-work, write:jira-work, offline_access,
# and set the callback URL to match ATLASSIAN_REDIRECT_URI below exactly.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:3000/api/jira/callback

# Session cookie name and sliding expiry window.
SESSION_COOKIE_NAME=ih_session
SESSION_TTL_DAYS=7

# Per-API-key rate limit for the external REST API (POST /api/v1/findings).
API_KEY_RATE_LIMIT_MAX=30
API_KEY_RATE_LIMIT_WINDOW_MS=60000

# NHI Blog Digest script (scripts/blog-digest.ts). Run: npm run digest.
# The backend must be running before you invoke the script.
ANTHROPIC_API_KEY=           # Anthropic API key for blog post summarization
DIGEST_API_KEY=              # IdentityHub API key (generate via POST /api/api-keys once the app is running)
DIGEST_PROJECT_KEY=          # Jira project key to file digest tickets into (e.g. NHI)
DIGEST_APP_URL=http://localhost:3000  # Base URL of the running IdentityHub backend
